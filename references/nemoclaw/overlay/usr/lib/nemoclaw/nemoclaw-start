#!/bin/sh
set -e

NEMOCLAW_HOME=/var/lib/nemoclaw
export PATH="/usr/lib/nemoclaw/node_modules/.bin:$PATH"
export NODE_PATH="/usr/lib/nemoclaw/node_modules"
export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# If not yet onboarded, run non-interactive onboard
# NemoClaw auto-detects local Ollama in non-interactive mode
if [ ! -f "$NEMOCLAW_HOME/.onboarded" ]; then
    echo "NemoClaw: Running first-time onboard..."

    # Wait for Ollama to be ready
    for i in $(seq 1 30); do
        if ollama list >/dev/null 2>&1; then break; fi
        echo "NemoClaw: Waiting for Ollama to be ready ($i/30)..."
        sleep 2
    done

    export NEMOCLAW_NON_INTERACTIVE=1
    export NEMOCLAW_PROVIDER=ollama
    nemoclaw onboard --non-interactive
    touch "$NEMOCLAW_HOME/.onboarded"
fi

# Start the NemoClaw agent
exec nemoclaw start
