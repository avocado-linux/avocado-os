#!/bin/sh
set -e

GPU_ARGS=""

# Detect NVIDIA GPU and enable GPU passthrough
if [ -e /dev/nvidia0 ] || [ -e /dev/nvhost-ctrl ]; then
    echo "NemoClaw: NVIDIA GPU detected, enabling GPU passthrough..."
    GPU_ARGS="--runtime nvidia --gpus all"
fi

exec docker run \
    --name nemoclaw-gateway \
    --rm \
    ${GPU_ARGS} \
    --network nemoclaw \
    -p "${NEMOCLAW_API_PORT:-3000}:3000" \
    -v /var/lib/nemoclaw/state:/root/.openclaw \
    -v /var/lib/nemoclaw/blueprints:/blueprints \
    -v /var/run/docker.sock:/var/run/docker.sock \
    -e "OPENCLAW_STATE_DIR=/root/.openclaw" \
    "${NEMOCLAW_IMAGE}"
