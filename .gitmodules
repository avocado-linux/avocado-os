[submodule "distro"]
	path = distro
	url = git@github.com:avocado-linux/meta-avocado.git
	branch = scarthgap
[submodule "extensions/cli/avocado-cli"]
	path = extensions/cli/avocado-cli
	url = git@github.com:avocado-linux/avocado-cli
	branch = main
[submodule "extensions/connect/avocado-conn"]
	path = extensions/connect/avocado-conn
	url = git@github.com:avocado-linux/avocado-conn.git
[submodule "extensions/tunnels/avocado-rat"]
	path = extensions/tunnels/avocado-rat
	url = git@github.com:avocado-linux/avocado-rat.git
[submodule "bsp/reterminal/seeed-linux-dtoverlays"]
	path = bsp/reterminal/seeed-linux-dtoverlays
	url = https://github.com/Seeed-Studio/seeed-linux-dtoverlays.git
[submodule "bsp/reterminal-dm/seeed-linux-dtoverlays"]
	path = bsp/reterminal-dm/seeed-linux-dtoverlays
