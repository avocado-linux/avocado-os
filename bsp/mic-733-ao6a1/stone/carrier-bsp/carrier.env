# Carrier-BSP env consumed by stone-provision-tegraflash.sh.
#
# MIC-733-AO6A1 is the 64GB SOM variant of the same MIC-733-AO carrier
# board the AO5A1 ships on. Carrier hardware is identical (4× MGBE,
# mini-PCIe, M.2, RS-232/422/485, etc.); only the AGX Orin SOM module
# differs (32GB on AO5A1 vs 64GB on AO6A1). The carrier-bsp files in
# this directory are therefore byte-identical to those under
# bsp/mic-733-ao5a1/stone/carrier-bsp/ — they are duplicated rather
# than symlinked because each BSP extension is packaged independently
# and symlinks across extensions don't survive the SDK bind mount.
#
# Same flash profile applies: `flash.sh jetson-agx-orin-devkit internal`
# (per Advantech's Flash SOP). Files use the same `-adv` carrier suffix
# convention as AO5A1.
#
# Generic knob shape:
#   CARRIER_FV_<NAME>=value   → patches <NAME> in flashvars
#   CARRIER_ENV_<NAME>=value  → patches <NAME> in .env.initrd-flash
# See bsp/icam-540/stone/carrier-bsp/carrier.env for a worked example
# that also overrides CHECK_BOARDID / CHECK_BOARDSKU / SDRAM BCTs, and
# meta-avocado-nvidia/docs/adding-a-jetson-carrier.md for the full
# walkthrough.

CARRIER_LABEL="Advantech MIC-733-AO6A1 (Jetson AGX Orin 64GB SOM, P3701-0005)"

# Kernel DTB — Advantech adds carrier I/O nodes (4× MGBE PHYs, USB hub,
# GPIO expanders, RS-232/422/485 chips) on top of the stock P3737 DTB.
# AO6A1 selects the SKU-0005 (64GB) variant the conf picks for board_sku
# 0005 — same carrier nodes as AO5A1's 0000 DTB, but with the 64GB
# SOM-specific power-management entries.
CARRIER_ENV_DTBFILE="tegra234-p3737-0000+p3701-0005-nv-adv.dtb"

# BPMP DTB — use the unmodified upstream tegra234-bpmp-3701-0005-3737-0000.dtb.
# p3701.conf.common's board_sku 0005 selector picks it already, so no
# CARRIER_FV_BPFDTB_FILE override is needed.
#
# Do not add MGBE power-domain `always-on` entries here. MB1 BCT on this
# board does not initialize GBE UPHY (see MB1 log `W> Skipping GBE UPHY
# config`); forcing MGBE on at the BPMP layer would cause the kernel /
# UEFI MGBE driver to probe an uninitialized UPHY at 0x03f60000 and trip
# a fatal AXI2APB → CBB SERR. MGBE bring-up belongs in MB1 BCT (UPHY +
# pinmux + carrier phy power), not BPMP DTB.

# Pinmux / pad-voltage / GPIO dtsi — carrier-side, identical regardless
# of SOM SKU (the carrier exposes the same I/O whether the module is
# 32GB or 64GB). p3701.conf.common defaults all SKUs to the
# -p3701-0000-a04 family for these files, so the carrier-mod we ship
# applies to both AO5A1 and AO6A1 without further differentiation.
CARRIER_FV_PINMUX_CONFIG="tegra234-mb1-bct-pinmux-p3701-0000-a04-adv.dtsi"
CARRIER_FV_PMC_CONFIG="tegra234-mb1-bct-padvoltage-p3701-0000-a04-adv.dtsi"

# MB2 BCT misc DTS — disables the carrier (CVB) EEPROM read at I2C0
# slave 0xac. The MIC-733-AO carrier has no EEPROM at that address;
# without this override MB2 aborts in "Prepare eeprom data" with
# `I2C: slave not found in slaves` and busy-spins, never reaching the
# USB-storage stage of initrd-flash. Same fix Advantech ships in
# their vendor BSP's tegra234-mb2-bct-common.dtsi.
#
# NOTE: the flashvar name is `MB2BCT_CFG`, not `MB2_BCT`. The shell
# variable in p3701.conf.common is MB2_BCT, but L4T's flash framework
# exports it into the generated `flashvars` under the renamed key
# MB2BCT_CFG (see `flashvars` line `MB2BCT_CFG="..."`); patching
# anything other than that key produces a silent no-op WARNING.
CARRIER_FV_MB2BCT_CFG="tegra234-mb2-bct-misc-p3701-0000-adv.dts"

# EEPROM-comparison values — accept the AGX Orin 64GB SOM (P3701-0005).
# tegraflash aborts if the SOM's EEPROM-reported boardid/boardsku don't
# match these. The MIC-733-AO5A1 32GB variant uses 3701/0000; setting
# this explicitly here prevents a 32GB module from being misflashed
# with the 64GB carrier extension.
CARRIER_FV_CHECK_BOARDID="3701"
CARRIER_FV_CHECK_BOARDSKU="0005"
