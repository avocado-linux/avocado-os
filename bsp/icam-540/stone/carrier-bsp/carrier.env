# Carrier-BSP env consumed by stone-provision-tegraflash.sh.
#
# Reproduces the carrier overrides baked into avocado-icam-540.conf today,
# so that `target: jetson-orin-nx + extensions: [avocado-bsp-icam-540]`
# produces a functionally equivalent build to `target: icam-540`.
#
# Generic knob shape:
#   CARRIER_FV_<NAME>=value   → patches <NAME> in flashvars
#   CARRIER_ENV_<NAME>=value  → patches <NAME> in .env.initrd-flash
# Filenames must exist in the merged BSP (carrier-bsp overlay + the
# MACHINE-baked tegraflash-bsp). carrier-bsp/ in this directory ships the
# Advantech-specific DTB / BPMP DTB / BPMP firmware; meta-tegra's
# tegraflash-bsp already has every P3767 SKU's pinmux / sdram dtsi.

CARRIER_LABEL="Advantech ICAM-540 (P3768-0000 + P3767-0001, 8GB SOM)"

# Kernel DTB — Advantech-specific (-nv suffix carries proper CSI/NVCSI for
# the ICAM500 camera).
CARRIER_ENV_DTBFILE="tegra234-p3768-0000+p3767-0001-nv.dtb"

# BPMP DTB (3509-a02 variant per Advantech's BSP flash log) and firmware
# blob — TE950M-A1 = the 8GB Orin chip. NVIDIA's p3767.conf.common picks
# BPMP firmware by chip SKU: D3/D4 → TE980M (16GB), D5/D6 → TE950M (8GB).
# Hardware verification: an icam-540 unit reports `MemTotal: 7789132 kB`
# (≈8GB), matching the D5/D6 chip family → TE950M. Using TE980M on an
# 8GB chip programs DRAM/power rails for a 16GB layout, which cascades
# into invalid WPR/ACR descriptors and breaks nvgpu's secure-firmware
# bootstrap (ACR_LSF_WPR error / `acr_falcon2_sysmem_desc invalid`),
# even though the userspace stack and /dev/nvidia* nodes look healthy.
CARRIER_FV_BPFDTB_FILE="tegra234-bpmp-3767-0001-3509-a02.dtb"
CARRIER_FV_BPF_FILE="bpmp_t234-TE950M-A1_prod.bin"

# Pinmux + pad-voltage dtsi — HDMI variants (default Orin NX BSP uses DP
# variants).
CARRIER_FV_PINMUX_CONFIG="tegra234-mb1-bct-pinmux-p3767-hdmi-a03.dtsi"
CARRIER_FV_PMC_CONFIG="tegra234-mb1-bct-padvoltage-p3767-hdmi-a03.dtsi"

# SDRAM init — SKU 0001 variant. Without these the default SKU 0000
# params get programmed and MB1's DRAM alias check fails with
# "Read/write mis-match".
CARRIER_FV_WB0SDRAM_BCT="tegra234-p3767-0001-wb0sdram-l4t.dts"
CARRIER_ENV_EMMC_BCTS="tegra234-p3767-0001-sdram-l4t.dts"

# EEPROM-comparison values — accept SKU 0001 SOM. Default jetson-orin-nx
# MACHINE bakes 3767 / 0000.
CARRIER_FV_CHECK_BOARDID="3767"
CARRIER_FV_CHECK_BOARDSKU="0001"
